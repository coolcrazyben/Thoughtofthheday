# ── Turso (SQLite cloud — required for Vercel) ───────────────────────────────
# Create a free database at https://turso.tech then run:
#   turso db show <db-name> --url    → paste as TURSO_DATABASE_URL
#   turso db tokens create <db-name> → paste as TURSO_AUTH_TOKEN
#
# For local dev without Turso:
#   Leave both blank — the app auto-creates ./data/local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — the app uses a weak default in dev only
JWT_SECRET=

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate a key pair once:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@yourdomain.com

# ── Email reminders (Resend) ───────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
# 1. Create an API key in the Resend dashboard → paste here
# 2. Verify your sending domain in Resend, then set RESEND_FROM_EMAIL
#    (without a verified domain, Resend only allows sending to your own email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Thought of the Day <noreply@yourdomain.com>

# ── Cron secret ───────────────────────────────────────────────────────────────
# Vercel automatically generates this and passes it to your cron endpoints.
# You can also set it manually for local testing:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then POST /api/cron/send-reminders with: Authorization: Bearer <secret>
CRON_SECRET=

# ── App URL ────────────────────────────────────────────────────────────────────
# Used in email links. Defaults to https://thoughtoftheday.vercel.app
APP_URL=
